generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  password      String?
  role          String     @default("USER")
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]
  reviews       Review[]
}

model BotProduct {
  id              String     @id @default(cuid())
  name            String
  productKey      String?    @unique
  description     String
  instrument      String
  strategyType    String
  riskLevel       String
  price           Float
  version         String     @default("1.0")
  ex5FilePath     String?
  pdfFilePath     String?
  isActive        Boolean    @default(true)
  timeframes      String?
  minCapital      Float?
  backtestResults String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  status          String     @default("ACTIVE")
  originalPrice   Float?
  purchases       Purchase[]
  reviews         Review[]
}

model Purchase {
  id                    String          @id @default(cuid())
  userId                String
  botProductId          String
  amount                Float
  status                String          @default("COMPLETED")
  lastDownloadedVersion String?
  createdAt             DateTime        @default(now())
  expiresAt             DateTime?
  lastSync              DateTime?
  updatedAt             DateTime        @updatedAt
  productKey            String?
  balance               Float?
  equity                Float?
  lastStatus            String?
  botSettings           BotSettings[]
  licenseSessions       LicenseSession?
  activePositions       LivePosition[]
  botProduct            BotProduct      @relation(fields: [botProductId], references: [id])
  user                  User            @relation(fields: [userId], references: [id])
  remoteCommands        RemoteCommand[]
  pastTrades            TradeHistory[]

  @@index([botProductId], map: "Purchase_botProductId_fkey")
  @@index([userId], map: "Purchase_userId_fkey")
}

model LicenseSession {
  id           String   @id @default(cuid())
  purchaseId   String   @unique
  account      String
  lastActivity DateTime @default(now())
  isActive     Boolean  @default(true)
  purchase     Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model RemoteCommand {
  id         String             @id @default(cuid())
  purchaseId String
  command    String
  value      String?
  createdAt  DateTime           @default(now())
  executions CommandExecution[]
  purchase   Purchase           @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model CommandExecution {
  id        String        @id @default(cuid())
  commandId String
  account   String
  createdAt DateTime      @default(now())
  command   RemoteCommand @relation(fields: [commandId], references: [id])

  @@unique([commandId, account])
  @@index([commandId])
}

model LivePosition {
  id         String   @id @default(cuid())
  purchaseId String
  ticket     String
  type       String
  symbol     String
  lots       Float
  openPrice  Float
  tp         Float
  sl         Float
  profit     Float
  updatedAt  DateTime @updatedAt
  account    String   @default("unknown")
  isReal     Boolean  @default(false)
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model TradeHistory {
  id         String   @id @default(cuid())
  purchaseId String
  ticket     String
  type       String
  symbol     String
  lots       Float
  openPrice  Float
  closePrice Float
  profit     Float
  closedAt   DateTime
  account    String   @default("unknown")
  isReal     Boolean  @default(false)
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model RequestLog {
  id        String   @id @default(cuid())
  path      String
  method    String
  body      String?  @db.Text
  error     String?  @db.Text
  createdAt DateTime @default(now())
}

model BotSettings {
  id         String   @id @default(cuid())
  purchaseId String
  account    String
  settings   String   @db.LongText
  updatedAt  DateTime @updatedAt
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@unique([purchaseId, account])
  @@index([purchaseId])
}

model Review {
  id           String     @id @default(cuid())
  rating       Int
  comment      String     @db.Text
  userId       String
  botProductId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  botProduct   BotProduct @relation(fields: [botProductId], references: [id])

  @@index([userId])
  @@index([botProductId])
}

