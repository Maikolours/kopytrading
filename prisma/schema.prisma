generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  password      String?
  role          String     @default("USER")
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]
}

model BotProduct {
  id              String     @id @default(cuid())
  name            String
  productKey      String?    @unique // Identifier for bots (e.g. XAU-MG)
  description     String
  instrument      String
  strategyType    String
  riskLevel       String
  price           Float
  originalPrice   Float?
  version         String     @default("1.0")
  ex5FilePath     String?
  pdfFilePath     String?
  isActive        Boolean    @default(true)
  timeframes      String?
  minCapital      Float?
  backtestResults String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  status          String     @default("ACTIVE")
  purchases       Purchase[]
}

model Purchase {
  id                    String          @id @default(cuid())
  userId                String
  botProductId          String
  productKey            String?         // Snapshotted productKey for safety
  amount                Float
  status                String          @default("COMPLETED")
  lastDownloadedVersion String?
  lastSync              DateTime?
  balance               Float?
  equity                Float?
  lastStatus            String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  expiresAt             DateTime?
  activePositions       LivePosition[]
  pastTrades            TradeHistory[]
  botSettings           BotSettings[]
  licenseSessions       LicenseSession[]
  botProduct            BotProduct      @relation(fields: [botProductId], references: [id])
  user                  User            @relation(fields: [userId], references: [id])
  remoteCommands        RemoteCommand[]

  @@index([botProductId], map: "Purchase_botProductId_fkey")
  @@index([userId], map: "Purchase_userId_fkey")
}

model LicenseSession {
  id           String   @id @default(cuid())
  purchaseId   String
  account      String
  lastActivity DateTime @default(now())
  isActive     Boolean  @default(true)
  purchase     Purchase @relation(fields: [purchaseId], references: [id])

  @@unique([purchaseId]) // One active session per purchase
  @@index([purchaseId])
}

model RemoteCommand {
  id         String             @id @default(cuid())
  purchaseId String
  command    String
  value      String?
  createdAt  DateTime           @default(now())
  purchase   Purchase           @relation(fields: [purchaseId], references: [id])
  executions CommandExecution[]

  @@index([purchaseId])
}

model CommandExecution {
  id        String        @id @default(cuid())
  commandId String
  account   String
  createdAt DateTime      @default(now())
  command   RemoteCommand @relation(fields: [commandId], references: [id])

  @@unique([commandId, account])
  @@index([commandId])
}

model LivePosition {
  id         String   @id @default(cuid())
  purchaseId String
  ticket     String
  type       String
  symbol     String
  lots       Float
  openPrice  Float
  tp         Float
  sl         Float
  profit     Float
  account    String   @default("unknown")
  isReal     Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model TradeHistory {
  id         String   @id @default(cuid())
  purchaseId String
  ticket     String
  type       String
  symbol     String
  lots       Float
  openPrice  Float
  closePrice Float
  profit     Float
  account    String   @default("unknown")
  isReal     Boolean  @default(false)
  closedAt   DateTime
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}


model RequestLog {
  id        String   @id @default(cuid())
  path      String
  method    String
  body      String?  @db.Text
  error     String?  @db.Text
  createdAt DateTime @default(now())
}

model BotSettings {
  id         String   @id @default(cuid())
  purchaseId String
  account    String
  settings   Json
  updatedAt  DateTime @updatedAt
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@unique([purchaseId, account])
  @@index([purchaseId])
}
