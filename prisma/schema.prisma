generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  password      String?
  role          String     @default("USER")
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]
}

model BotProduct {
  id              String     @id @default(cuid())
  name            String
  description     String
  instrument      String
  strategyType    String
  riskLevel       String
  price           Float
  version         String     @default("1.0")
  ex5FilePath     String?
  pdfFilePath     String?
  isActive        Boolean    @default(true)
  timeframes      String?
  minCapital      Float?
  backtestResults String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  status          String     @default("ACTIVE")
  purchases       Purchase[]
}

model Purchase {
  id                    String          @id @default(cuid())
  userId                String
  botProductId          String
  amount                Float
  status                String          @default("COMPLETED")
  lastDownloadedVersion String?
  lastSync              DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  expiresAt       DateTime?
  activePositions LivePosition[]
  pastTrades      TradeHistory[]
  botProduct      BotProduct      @relation(fields: [botProductId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  remoteCommands  RemoteCommand[]

  @@index([botProductId], map: "Purchase_botProductId_fkey")
  @@index([userId], map: "Purchase_userId_fkey")
}

model RemoteCommand {
  id         String             @id @default(cuid())
  purchaseId String
  command    String
  value      String?
  createdAt  DateTime           @default(now())
  purchase   Purchase           @relation(fields: [purchaseId], references: [id])
  executions CommandExecution[]

  @@index([purchaseId])
}

model CommandExecution {
  id        String        @id @default(cuid())
  commandId String
  account   String
  createdAt DateTime      @default(now())
  command   RemoteCommand @relation(fields: [commandId], references: [id])

  @@unique([commandId, account])
  @@index([commandId])
}

model LivePosition {
  id         String   @id @default(cuid())
  purchaseId String
  ticket     String
  type       String
  symbol     String
  lots       Float
  openPrice  Float
  tp         Float
  sl         Float
  profit     Float
  account    String   @default("unknown")
  updatedAt  DateTime @updatedAt
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model TradeHistory {
  id         String   @id @default(cuid())
  purchaseId String
  ticket     String
  type       String
  symbol     String
  lots       Float
  openPrice  Float
  closePrice Float
  profit     Float
  account    String   @default("unknown")
  closedAt   DateTime
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
}

model RequestLog {
  id        String   @id @default(cuid())
  path      String
  method    String
  body      String?  @db.Text
  error     String?  @db.Text
  createdAt DateTime @default(now())
}
